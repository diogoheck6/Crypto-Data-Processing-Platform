# ==============================================================================
# Crypto Data Processing Platform — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ==============================================================================


# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------

# Connection URL for the main application database.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto_db

# Connection URL for the isolated test database.
# Used only during test runs — never shares data with the main DB.
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5433/crypto_test_db

# PostgreSQL connection pool settings (optional, tune for production)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30


# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------

# Redis connection URL for the task queue (RQ) and cache.
# Format: redis://<host>:<port>/<db_number>
REDIS_URL=redis://localhost:6379/0

# Optional: separate URL for the test queue
REDIS_TEST_URL=redis://localhost:6379/1


# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# Set to "true" to enable debug mode (verbose errors, reload on change).
# Must be "false" in production.
DEBUG=true

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Application environment identifier. Used in structured log output.
# Values: local | staging | production
ENVIRONMENT=local

# Maximum allowed CSV file upload size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Allowed CORS origins (comma-separated). Use "*" for local dev only.
# Example for production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=*


# ------------------------------------------------------------------------------
# Security / Secrets
# ------------------------------------------------------------------------------

# Secret key used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. Any non-empty string works for local dev.
SECRET_KEY=change-me-in-production

# JWT token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Algorithm used for JWT signing
JWT_ALGORITHM=HS256


# ------------------------------------------------------------------------------
# Azure (Phase 8 — Production only)
# ------------------------------------------------------------------------------

# Azure Blob Storage connection string for CSV file uploads
# AZURE_STORAGE_CONNECTION_STRING=

# Azure Blob Storage container name
# AZURE_STORAGE_CONTAINER_NAME=csv-uploads

# Azure Key Vault URI (used to retrieve secrets in production)
# AZURE_KEY_VAULT_URI=

# Application Insights instrumentation key (for structured log ingestion)
# APPLICATIONINSIGHTS_CONNECTION_STRING=
